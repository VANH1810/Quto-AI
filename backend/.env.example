# Sao chép thành .env rồi chỉnh khi cần. Mặc định chạy full mock, KHÔNG cần key.
APP_NAME=Ban Tin An Toan - Dien Bien EWS
APP_VERSION=0.1.0

# Nguồn thời tiết: openmeteo (thật) | mock (offline)
WEATHER_PROVIDER=openmeteo
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# LLM sinh bản tin: mock | openai | gemini | local
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# TTS đọc bản tin (tiếng dân tộc): mock | mms  (mms = Meta MMS VITS, cần GPU/thư viện)
TTS_PROVIDER=mock

# Kênh gửi: mock (in log) | live (cắm Zalo ZNS/SMS thật)
DISPATCH_PROVIDER=mock

# Ngưỡng cấp độ cần người duyệt (human-in-the-loop). >=3 = cam/đỏ/tím.
HUMAN_APPROVAL_MIN_LEVEL=3

# Lưu trữ: memory (chạy ngay, in-memory) | supabase (Postgres).
# Khi = supabase: chạy db/schema.sql trên Supabase rồi điền URL + service_role key.
DB_BACKEND=memory
SUPABASE_URL=
SUPABASE_KEY=

# JWT cho admin
JWT_SECRET=dev-secret-doi-truoc-khi-len-that
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

# Frontend map và admin console local.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
