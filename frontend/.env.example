# local | blob | api. Biến server-only, không dùng tiền tố NEXT_PUBLIC_.
APP_DATA_SOURCE=local
# Dùng khi APP_DATA_SOURCE=api.
APP_BACKEND_URL=https://quto-ai.onrender.com
# URL đầy đủ của quto-data.snapshot.json trong Private Vercel Blob.
APP_DATA_BLOB_URL=
# Vercel tự cấp VERCEL_OIDC_TOKEN khi Blob store được connect với project.
# Local fallback (không commit giá trị thật): BLOB_READ_WRITE_TOKEN=
# Chỉ bật ở local để tải snapshot từ /api/data/snapshot.
ALLOW_MOCK_SNAPSHOT_EXPORT=false
# URL public chỉ còn dùng cho đăng nhập/kiểm tra phiên admin từ trình duyệt.
NEXT_PUBLIC_API_BASE_URL=https://quto-ai.onrender.com
