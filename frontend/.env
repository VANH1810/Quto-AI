# mock | api — giữ mock để bản đồ không gọi backend.
NEXT_PUBLIC_DATA_SOURCE=mock
# Chế độ mock dùng dữ liệu đã commit cho cả Home/bản đồ và /forecast, không cần backend.
# Chỉ dùng URL này cho đăng nhập và kiểm tra phiên admin.
NEXT_PUBLIC_API_BASE_URL=https://quto-ai.onrender.com
# true: toàn bộ dữ liệu dashboard admin dùng mock; đăng nhập vẫn gọi API thật.
NEXT_PUBLIC_USE_MOCKS=true
