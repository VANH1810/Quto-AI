# Cấu hình gốc repo (dùng khi chạy agent_worker / backend ngoài Docker).
# Trong docker-compose các biến này đã set sẵn theo service.

# --- Hạ tầng (bắt buộc khi chạy agent_worker) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://quto:quto@localhost:5432/quto
BACKEND_URL=http://localhost:8000            # callback ghi notifications về backend
SERVICE_TOKEN=doi-chuoi-bi-mat-nay           # phải TRÙNG SERVICE_TOKEN của backend

# --- LLM (agent tool-calling BẮT BUỘC endpoint OpenAI-compatible; 'mock' KHÔNG chạy agent) ---
LLM_PROVIDER=fpt             # openai | local | fpt
# FPT Cloud (OpenAI-compatible, dùng openai SDK):
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com/v1/
FPT_MODEL=DeepSeek-V4-Flash
# hoặc OpenAI chuẩn:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Agent ---
HUMAN_APPROVAL_MIN_LEVEL=3   # cấp >= ngưỡng phải chờ cán bộ duyệt

# --- Bản đồ/định tuyến (none | serpapi) — km/phút đường thật + POI trú ẩn ---
ROUTE_PROVIDER=none          # 'serpapi' để bật
SERPAPI_KEY=

# --- Nguồn dữ liệu (local = Postgres seed | supabase = dữ liệu THẬT) ---
DATA_SOURCE=local            # 'supabase' để agent đọc citizens/admins/shelters từ Supabase
SUPABASE_URL=
SUPABASE_KEY=                # service_role key
MIRROR_NOTIFICATIONS_SUPABASE=true
PREFETCH=8
DISPATCH_MAX_RETRY=3

# --- Telegram (gửi cảnh báo thật) ---
TELEGRAM_PROVIDER=mock       # mock | live  (đặt 'live' để gửi thật)
TELEGRAM_BOT_TOKEN=          # từ @BotFather
